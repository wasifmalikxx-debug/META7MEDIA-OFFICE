# ──────────────────────────────────────────────────────────────
# Office Manager — environment variables
# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env` to git (it is already gitignored).
# ──────────────────────────────────────────────────────────────

# Database (Supabase — use the pooled and direct URLs from your project)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# NextAuth — secret for signing session cookies. Generate with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL="http://localhost:3000"

# WhatsApp (Meta Cloud API) — leave META_WA_ENABLED unset to disable WhatsApp
META_WA_ENABLED="false"
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=

# Cron — random string; Vercel sends it as `Authorization: Bearer <secret>` on cron requests
CRON_SECRET=

# Branding — shown in the sidebar and on the login page
NEXT_PUBLIC_APP_NAME="Office Manager"
